// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Seed script configuration
// Run with: npm run db:seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          String    @default("BUYER") // BUYER, REALTOR, ADMIN
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  purchasedReports Purchase[]
  reportCredits ReportCredit[]
  propertyClaims PropertyClaim[]
  createdProperties Property[] @relation("UserCreatedProperties")
  workRecordsEntered WorkRecord[] @relation("UserEnteredWorkRecords")
  maintenanceRecordsEntered MaintenanceRecord[] @relation("UserEnteredMaintenanceRecords")
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Property {
  id          String   @id @default(cuid())
  address     String
  city        String
  state       String
  zipCode     String
  propertyType String  // e.g., "Single Family", "Condo", "Townhouse"
  yearBuilt   Int?
  squareFeet  Int?
  lotSize     Float?
  source      String   @default("SYSTEM") // SYSTEM, USER, PARTNER
  createdByUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  salesHistory       Sale[]
  workHistory        WorkRecord[]
  insuranceClaims    InsuranceClaim[]
  warranties         Warranty[]
  reports            Report[]
  titleIssues        TitleIssue[]
  usageHistory       UsageRecord[]
  environmentalAssessments EnvironmentalAssessment[]
  maintenanceRecords MaintenanceRecord[]
  claims            PropertyClaim[]
  
  createdByUser     User?     @relation("UserCreatedProperties", fields: [createdByUserId], references: [id], onDelete: SetNull)
  
  @@unique([address, city, state, zipCode])
  @@map("properties")
}

model PropertyClaim {
  id              String   @id @default(cuid())
  propertyId      String
  userId          String
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, PENDING
  verificationStatus String @default("UNVERIFIED") // UNVERIFIED, VERIFIED, REJECTED
  claimedAt       DateTime @default(now())
  notes           String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("property_claims")
}

model Sale {
  id          String   @id @default(cuid())
  propertyId  String
  saleDate    DateTime
  salePrice   Float
  buyerName   String?
  sellerName  String?
  saleType    String   // e.g., "Standard", "Foreclosure", "Short Sale"
  recordedDate DateTime?
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("sales")
}

model WorkRecord {
  id            String   @id @default(cuid())
  propertyId    String
  workType      String   // e.g., "Roofing", "Plumbing", "Electrical", "HVAC"
  description   String
  contractor    String?
  contractorLicense String?
  workDate      DateTime
  cost          Float?
  permitNumber  String?
  permitIssued  Boolean  @default(false)
  warrantyYears Int?    // Warranty period in years
  warrantyExpires DateTime?
  dataSource    String   @default("SYSTEM") // SYSTEM, USER, COMPANY
  enteredByUserId String?
  createdAt     DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  enteredByUser User? @relation("UserEnteredWorkRecords", fields: [enteredByUserId], references: [id], onDelete: SetNull)
  
  @@map("work_records")
}

model InsuranceClaim {
  id          String   @id @default(cuid())
  propertyId  String
  claimDate   DateTime
  claimType   String   // e.g., "Water Damage", "Fire", "Storm", "Theft"
  claimAmount Float?
  status      String   // e.g., "Approved", "Denied", "Pending"
  description String?
  insuranceCompany String?
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("insurance_claims")
}

model Warranty {
  id            String   @id @default(cuid())
  propertyId    String
  warrantyType  String   // e.g., "Home Warranty", "Manufacturer", "Contractor"
  provider      String
  startDate     DateTime
  endDate       DateTime
  coverage      String?  // Description of what's covered
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("warranties")
}

model Report {
  id          String   @id @default(cuid())
  propertyId  String
  reportNumber String  @unique
  generatedAt DateTime @default(now())
  price       Float
  status      String   @default("PENDING") // PENDING, GENERATED, EXPIRED
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  creditUsages CreditUsage[]
  
  @@map("reports")
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  amount    Float
  paymentId String?  // Payment processor transaction ID
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  purchasedAt DateTime @default(now())
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  @@map("purchases")
}

model ReportCredit {
  id          String   @id @default(cuid())
  userId      String
  credits     Int      // Number of report credits
  packType    String   // SINGLE, PACK_3, PACK_5, PACK_10
  amount      Float    // Total amount paid
  paymentId   String?  // Payment processor transaction ID
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  purchasedAt DateTime @default(now())
  expiresAt   DateTime? // Optional expiration date
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedCredits CreditUsage[]
  
  @@map("report_credits")
}

model CreditUsage {
  id            String   @id @default(cuid())
  creditId      String
  reportId      String
  usedAt        DateTime @default(now())
  
  credit ReportCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)
  report Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  @@unique([creditId, reportId])
  @@map("credit_usage")
}

model TitleIssue {
  id          String   @id @default(cuid())
  propertyId  String
  issueType   String   // e.g., "Lien", "Foreclosure", "Tax Lien", "HOA Lien", "Title Dispute"
  description String
  recordedDate DateTime
  resolvedDate DateTime?
  isResolved  Boolean  @default(false)
  amount      Float?
  recordedBy  String?  // e.g., "County Recorder", "HOA", "IRS"
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("title_issues")
}

model UsageRecord {
  id          String   @id @default(cuid())
  propertyId  String
  usageType   String   // e.g., "Owner Occupied", "Rental", "Short-term Rental", "Commercial", "Vacant"
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("usage_records")
}

model EnvironmentalAssessment {
  id          String   @id @default(cuid())
  propertyId  String
  assessmentType String // e.g., "Lead Paint", "Asbestos", "Radon", "Mold", "Flood Zone", "Soil Contamination"
  assessmentDate DateTime
  result      String   // e.g., "Pass", "Fail", "Presence Detected", "No Issues"
  details     String?
  inspector   String?
  reportUrl   String?
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("environmental_assessments")
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  propertyId  String
  maintenanceType String // e.g., "HVAC Service", "Roof Inspection", "Plumbing Check", "Electrical Inspection", "Foundation Inspection"
  serviceDate DateTime
  nextDueDate DateTime?
  serviceProvider String?
  notes       String?
  cost        Float?
  dataSource  String   @default("SYSTEM")
  enteredByUserId String?
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  enteredByUser User? @relation("UserEnteredMaintenanceRecords", fields: [enteredByUserId], references: [id], onDelete: SetNull)
  
  @@map("maintenance_records")
}

