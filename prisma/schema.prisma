// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Seed script configuration
// Run with: npm run db:seed

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("BUYER") // BUYER, REALTOR, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  purchasedReports Purchase[]
  
  @@map("users")
}

model Property {
  id          String   @id @default(cuid())
  address     String
  city        String
  state       String
  zipCode     String
  propertyType String  // e.g., "Single Family", "Condo", "Townhouse"
  yearBuilt   Int?
  squareFeet  Int?
  lotSize     Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  salesHistory    Sale[]
  workHistory     WorkRecord[]
  insuranceClaims InsuranceClaim[]
  warranties      Warranty[]
  reports         Report[]
  
  @@unique([address, city, state, zipCode])
  @@map("properties")
}

model Sale {
  id          String   @id @default(cuid())
  propertyId  String
  saleDate    DateTime
  salePrice   Float
  buyerName   String?
  sellerName  String?
  saleType    String   // e.g., "Standard", "Foreclosure", "Short Sale"
  recordedDate DateTime?
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("sales")
}

model WorkRecord {
  id            String   @id @default(cuid())
  propertyId    String
  workType      String   // e.g., "Roofing", "Plumbing", "Electrical", "HVAC"
  description   String
  contractor    String?
  contractorLicense String?
  workDate      DateTime
  cost          Float?
  permitNumber  String?
  permitIssued  Boolean  @default(false)
  warrantyYears Int?    // Warranty period in years
  warrantyExpires DateTime?
  createdAt     DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("work_records")
}

model InsuranceClaim {
  id          String   @id @default(cuid())
  propertyId  String
  claimDate   DateTime
  claimType   String   // e.g., "Water Damage", "Fire", "Storm", "Theft"
  claimAmount Float?
  status      String   // e.g., "Approved", "Denied", "Pending"
  description String?
  insuranceCompany String?
  createdAt   DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("insurance_claims")
}

model Warranty {
  id            String   @id @default(cuid())
  propertyId    String
  warrantyType  String   // e.g., "Home Warranty", "Manufacturer", "Contractor"
  provider      String
  startDate     DateTime
  endDate       DateTime
  coverage      String?  // Description of what's covered
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@map("warranties")
}

model Report {
  id          String   @id @default(cuid())
  propertyId  String
  reportNumber String  @unique
  generatedAt DateTime @default(now())
  price       Float
  status      String   @default("PENDING") // PENDING, GENERATED, EXPIRED
  
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  
  @@map("reports")
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  amount    Float
  paymentId String?  // Payment processor transaction ID
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  purchasedAt DateTime @default(now())
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  @@map("purchases")
}

